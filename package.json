{
  "name": "smart-home-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3002",
    "dev:api": "node src/index.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:frontend\" \"npm run dev\"",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "clean": "taskkill /f /im node.exe 2>nul || echo No Node processes to kill",
    "clean:cache": "rmdir /s /q .next 2>nul || echo .next already clean",
    "clean:full": "npm run clean && npm run clean:cache && del tsconfig.tsbuildinfo 2>nul || echo Build info clean",
    "clean:rebuild": "npm run clean:full && npm cache clean --force",
    "restore:ports": "restore-dual-server.bat",
    "fix:all": "fix-all-issues.bat",
    "start:clean": "npm run clean && npm run dev",
    "build": "npx prisma generate && next build && next export",
    "build:production": "npx prisma generate && next build && next export",
    "start": "npx prisma generate && node src/index.js",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build:frontend && npm run build",
    "start:api": "node src/index.js",
    "start:production": "npm run db:generate && npm run start:api",
    "lint": "next lint",
    "setup": "npm install && cd frontend && npm install",
    "db:migrate": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:seed": "node src/seed-proposal-data.js",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@hello-pangea/dnd": "^16.6.0",
    "@mui/icons-material": "^6.2.0",
    "@mui/material": "^6.2.0",
    "@mui/x-date-pickers": "^7.22.1",
    "@prisma/client": "^6.8.2",
    "@types/formidable": "^3.4.5",
    "@types/react-color": "^3.0.12",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "formidable": "^3.5.4",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0",
    "next": "^15.1.6",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.3",
    "openai": "^4.75.0",
    "prisma": "^6.8.2",
    "react": "^18.3.1",
    "react-color": "^2.19.3",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.8",
    "recharts": "^2.15.3",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.54",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
